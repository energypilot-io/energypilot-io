{
    "name": "energypilot-io",
    "version": "0.1",
    "scripts": {
        "ng": "ng",
        "start": "concurrently \"npm run server\" \"npm run app\"",
        "start-ui-remote-server": "ng serve --port 3333 --proxy-config proxy.config.remote-server.json",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "app": "ng serve --port 3333 --proxy-config proxy.config.json",
        "server": "cd server & nodemon --watch server",
        "extract-i18n": "ng extract-i18n --format=json --output-path=src/locale",
        "lint": "ng lint"
    },
    "private": true,
    "dependencies": {
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "@ng-bootstrap/ng-bootstrap": "^20.0.0",
        "@ng-icons/core": "^33.1.0",
        "@ng-icons/tabler-icons": "^33.1.0",
        "@ngx-formly/bootstrap": "^7.1.0",
        "@ngx-formly/core": "^7.1.0",
        "@ngx-translate/core": "^17.0.0",
        "@ngx-translate/http-loader": "^17.0.0",
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3.6",
        "concurrently": "^9.2.1",
        "date-fns": "^4.1.0",
        "echarts": "^6.0.0",
        "ngx-device-detector": "^11.0.0",
        "ngx-echarts": "^21.0.0",
        "ngx-skeleton-loader": "^12.0.0",
        "ngx-socket-io": "^4.10.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.0",
        "@angular/cli": "^21.2.0",
        "@angular/compiler-cli": "^21.2.0",
        "@angular/localize": "^21.2.0",
        "@eslint/js": "^10.0.1",
        "@ngx-formly/schematics": "^7.1.0",
        "@types/jasmine": "~5.1.0",
        "@types/lodash": "^4.17.24",
        "angular-eslint": "21.3.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "jasmine-core": "~5.9.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2",
        "typescript-eslint": "8.56.1"
    }
}
